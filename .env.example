DB_USER=postgres
DB_PASSWORD=postgres
EX_COOKIES=ipb_member_id=YOUR_ID;ipb_pass_hash=YOUR_HASH;sk=YOUR_SK
EX_BASE_URL=https://exhentai.org
# EX_BASE_URL=https://e-hentai.org
RATE_INTERVAL=2.0
THUMB_RATE_INTERVAL=0.5
THUMB_WORKERS=1
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/eh_stash
TAG_BLACKLIST=male:yaoi,female:amputee,female:futanari
# PROXY_URL=http://user:pass@host:port

# ─── pi-sync (Pi → Neon + R2) ──────────────────────────────────────────────
# Neon pooled connection string (from Neon console)
NEON_DSN=postgresql://USER:PASS@ep-XXXX-pooler.REGION.aws.neon.tech/neondb?sslmode=require
# R2 — generate a Pi-scoped token (Object Read+Write on the thumb bucket)
R2_ENDPOINT=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com
R2_BUCKET=eh-stash-thumbs
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
# Cadence: 300=5min (initial), bump to 1800=30min once caught up
SYNC_CADENCE_SEC=300
SYNC_CHUNK_ROT=5000
SYNC_OUTBOX_BATCH=500