# Public (ehstash.com) build mode.
# Copy to .env.public and fill in, then run `pnpm build:public`.
#
# VITE_APP_MODE: must be "public" to activate public mode.
VITE_APP_MODE=public

# VITE_API_BASE_URL: base URL of the Cloudflare Worker.
#   - dev:    http://localhost:8787
#   - prod:   https://api.ehstash.com
VITE_API_BASE_URL=

# VITE_THUMB_BASE_URL: public origin where thumbnails are served from R2.
#   - r2.dev:        https://pub-<hash>.r2.dev
#   - custom domain: https://thumbs.ehstash.com
# Trailing slash is stripped automatically; don't include it here.
VITE_THUMB_BASE_URL=
